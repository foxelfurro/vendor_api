# =============================================================================
# Variables de entorno — vendor-hub-api
#
# Copia este archivo como .env y completa los valores antes de iniciar el
# servidor. NUNCA subas el archivo .env real al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
# Puerto en el que escucha Express. Render y Railway lo asignan automáticamente.
PORT=3000

# Entorno de ejecución. Afecta el nivel de logging y comportamientos de seguridad.
# Valores: development | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db?sslmode=require
# Neon, Supabase y Railway exponen esta URL en su panel de control.
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Autenticación JWT
# Genera un secreto seguro con: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# Frontend
# URL base del frontend. Se usa para construir las URLs de retorno del Checkout
# de Stripe (success_url / cancel_url) y los enlaces en correos.
# En desarrollo: http://localhost:5173
# En producción: https://lumin.qlatte.com
# -----------------------------------------------------------------------------
FRONTEND_URL=https://lumin.qlatte.com

# =============================================================================
# Stripe (pasarela de pagos)
# Documentación: https://stripe.com/docs/api
# Panel: https://dashboard.stripe.com
#
# NOTA: además de las variables de abajo, habilita el Billing Portal en el panel
# (Settings -> Billing -> Customer portal). Lo usa el endpoint /payments/portal
# para que las personas gestionen y renueven su suscripción.
# =============================================================================

# Llave SECRETA de Stripe.
# - Pruebas:    empieza con "sk_test_"
# - Producción: empieza con "sk_live_"
# Usa la de PRUEBAS en desarrollo; la de PRODUCCIÓN solo en el servidor real.
# Panel → Developers → API keys.
STRIPE_SECRET_KEY=

# ID del precio (Price) de la suscripción mensual. Empieza con "price_".
# Se crea en el panel: Product catalog → tu producto → Pricing.
# IMPORTANTE: el precio debe ser de tipo "recurring" (recurrente, mensual);
# el Checkout se abre en modo 'subscription' y fallará con un precio de pago único.
STRIPE_PRICE_ID=

# Secreto de firma del webhook. Empieza con "whsec_".
# Se obtiene al registrar el endpoint del webhook en el panel:
#   Developers → Webhooks → Add endpoint
#   URL del endpoint:  https://TU-API/webhooks/stripe
#   Eventos a escuchar:
#     - checkout.session.completed
#     - invoice.payment_succeeded
#     - invoice.payment_failed
#     - customer.subscription.updated
#     - customer.subscription.deleted
# En desarrollo, `stripe listen` imprime un whsec_ propio para el reenvío local.
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Captcha — Cloudflare Turnstile
# Panel: https://dash.cloudflare.com → Turnstile
# =============================================================================

# Llave SECRETA del servidor (la "site key" pública va en el frontend, en .env del cliente).
TURNSTILE_SECRET_KEY=

# =============================================================================
# Correo transaccional — Resend
# Panel: https://resend.com → API Keys
# Se usa para: recuperación de contraseña y notificaciones del sistema.
# =============================================================================
RESEND_API_KEY=

# Dirección de remitente verificada en Resend (dominio propio recomendado).
# Ejemplo: admin@qlatte.com
# Resend requiere que este dominio esté verificado en su panel.
RESEND_FROM_EMAIL=admin@qlatte.com
