# =============================================================================
# Variables de entorno — vendor-hub-api
#
# Copia este archivo como .env y completa los valores antes de iniciar el
# servidor. NUNCA subas el archivo .env real al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
# Puerto en el que escucha Express. Render y Railway lo asignan automáticamente.
PORT=3000

# Entorno de ejecución. Afecta el nivel de logging y comportamientos de seguridad.
# Valores: development | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db?sslmode=require
# Neon, Supabase y Railway exponen esta URL en su panel de control.
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Autenticación JWT
# Genera un secreto seguro con: openssl rand -hex 64
# -----------------------------------------------------------------------------
JWT_SECRET=

# -----------------------------------------------------------------------------
# Frontend
# URL base del frontend. Se usa para construir las URLs de retorno de pago
# (success_url / failure_url de Conekta) y los enlaces en correos.
# En desarrollo: http://localhost:5173
# En producción: https://lumin.qlatte.com
# -----------------------------------------------------------------------------
FRONTEND_URL=https://lumin.qlatte.com

# =============================================================================
# Conekta (pasarela de pagos)
# Documentación: https://developers.conekta.com
# =============================================================================

# Llave PRIVADA de Conekta (empieza con "key_").
# Usa la llave de PRUEBAS en desarrollo; la de PRODUCCIÓN solo en el servidor real.
CONEKTA_PRIVATE_KEY=

# ID del plan de suscripción mensual en Conekta.
# Si el plan no existe, la API lo crea automáticamente la primera vez que
# alguien paga con tarjeta recurrente.
CONEKTA_PLAN_ID=lumin-suscripcion-mensual

# Precio de la suscripción en CENTAVOS de peso mexicano.
# Ejemplos: 29900 = $299.00 MXN | 19900 = $199.00 MXN
CONEKTA_PRECIO_CENTAVOS=29900

# Métodos de pago habilitados para pagos únicos (no recurrentes), separados por coma.
# IMPORTANTE: incluye SOLO los métodos que ya estén ACTIVADOS en tu cuenta de Conekta.
# Solicitar un método no habilitado hace que Conekta rechace la orden completa.
#   card             → Solo tarjeta (valor seguro por defecto)
#   card,cash        → Tarjeta + OXXO (requiere habilitar "cash" en el panel)
#   card,bank_transfer → Tarjeta + SPEI (requiere habilitar "bank_transfer")
#   card,cash,bank_transfer → Todos los métodos
CONEKTA_METODOS=card

# Secreto del webhook: cadena larga y aleatoria (mínimo 32 caracteres).
# Se incluye en la URL del webhook que registras en el panel de Conekta:
#   https://TU-API/webhooks/conekta/EL_VALOR_DE_ESTA_VARIABLE
# Genera uno con: openssl rand -hex 32
CONEKTA_WEBHOOK_SECRET=

# =============================================================================
# Captcha — Cloudflare Turnstile
# Panel: https://dash.cloudflare.com → Turnstile
# =============================================================================

# Llave SECRETA del servidor (la "site key" pública va en el frontend, en .env del cliente).
TURNSTILE_SECRET_KEY=

# =============================================================================
# Correo transaccional — Resend
# Panel: https://resend.com → API Keys
# Se usa para: recuperación de contraseña y notificaciones del sistema.
# =============================================================================
RESEND_API_KEY=

# Dirección de remitente verificada en Resend (dominio propio recomendado).
# Ejemplo: admin@qlatte.com
# Resend requiere que este dominio esté verificado en su panel.
RESEND_FROM_EMAIL=admin@qlatte.com
