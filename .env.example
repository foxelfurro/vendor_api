# =============================================================================
# Variables de entorno — vendor-hub-api
# Copia este archivo como .env y completa los valores.
# =============================================================================

# --- Servidor ---
PORT=3000

# --- Base de datos (PostgreSQL / Neon) ---
DATABASE_URL=

# --- Autenticación ---
JWT_SECRET=

# --- Frontend (se usa para las URLs de retorno tras pagar) ---
FRONTEND_URL=https://lumin.qlatte.com

# =============================================================================
# Conekta (pasarela de pagos)
# =============================================================================
# Llave PRIVADA de Conekta (empieza con "key_"). Usa la de pruebas en desarrollo
# y la de producción en el servidor real.
CONEKTA_PRIVATE_KEY=

# Id del plan de suscripción mensual. Si el plan no existe en Conekta, la API lo
# crea automáticamente la primera vez que alguien paga con tarjeta.
CONEKTA_PLAN_ID=lumin-suscripcion-mensual

# Precio de la suscripción en CENTAVOS de peso mexicano (29900 = $299.00 MXN).
CONEKTA_PRECIO_CENTAVOS=29900

# Secreto del webhook: cualquier cadena larga y aleatoria. Forma parte de la URL
# del webhook que debes registrar en el panel de Conekta:
#   https://TU-API/webhooks/conekta/EL_VALOR_DE_ESTA_VARIABLE
CONEKTA_WEBHOOK_SECRET=

# =============================================================================
# Captcha — Cloudflare Turnstile
# =============================================================================
TURNSTILE_SECRET_KEY=

# =============================================================================
# Correo
# =============================================================================
# Resend (envío transaccional: recuperación de contraseña, avisos)
RESEND_API_KEY=

# SMTP (nodemailer), solo si se usa correo por SMTP
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASS=
